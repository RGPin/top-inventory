<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/index.css" />
    <title>Document</title>
  </head>
  <body>
    <div class="app-layout">
      <aside class="sidebar">
        <h2>Categories</h2>
        <ul class="category-list">
          <li>
            <a href="/inventory" class="<%= typeof currentCategory === 'undefined' ? 'active' : '' %>">All Parts</a>
          </li>
          <% categories.forEach(cat => { %>
            <li>
              <a href="/inventory/<%= cat.name %>" 
                class="<%= typeof currentCategory !== 'undefined' && currentCategory === cat.name ? 'active' : '' %>">
                <%= cat.name %>
              </a>
            </li>
          <% }) %>
        </ul>
      </aside>

      <main class="main-content">
        <div class="content-header">
          <h1>PC Parts Inventory</h1>
          <a href="/parts/new" class="btn btn-add">+ Add New Part</a>
        </div>

        <%- include("partials/grid.ejs") %>
      </main>
    </div>
  </body>
</html>
