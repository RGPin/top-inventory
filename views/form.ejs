<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/edit.css" />
  <title><%= details ? 'Edit - ' + details.name : 'Add New PC Part' %></title>
</head>
<body>

  <h1><%= details ? 'Edit PC Part' : 'Add New PC Part' %></h1>
  
  <form action="<%= details ? '/parts/' + details.id + '/edit' : '/parts/new' %>" method="POST">
    
    <div class="form-group">
      <label for="brand">Brand</label>
      <input type="text" id="brand" name="brand" value="<%= details? details.brand : '' %>" required>
    </div>

    <div class="form-group">
      <label for="name">Name</label>
      <input type="text" id="name" name="name" value="<%= details ? details.name : '' %>" required>
    </div>

    <div class="form-group">
      <label for="category_id">Category</label>
      <select id="category_id" name="category_id" required>
        <option value="" disabled <%= !details ? 'selected' : '' %>>Select a category</option>
        <% categories.forEach(cat => { %>
          <option value="<%= cat.id %>" <%= details && cat.id === details.category_id ? 'selected' : '' %>>
            <%= cat.name %>
          </option>
        <% }) %>
      </select>
    </div>

    <div class="form-group">
      <label for="price">Price ($)</label>
      <input type="number" id="price" name="price" step="0.01" min="0" value="<%= details ? details.price : '0.00' %>" required>
    </div>

    <div class="form-group">
      <label for="quantity">Quantity</label>
      <input type="number" id="quantity" name="quantity" min="0" value="<%= details ? details.quantity : 0 %>" required>
    </div>

    <div class="form-group">
      <label for="rating">Rating (0.00 - 5.00)</label>
      <input type="number" id="rating" name="rating" step="0.1" min="0" max="5" value="<%= details ? details.rating : 0 %>" required>
    </div>

    <div class="form-group">
      <label for="image_url">Image URL</label>
      <input type="text" id="image_url" name="image_url" value="<%= details ? details.image_url : '' %>">
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea id="description" name="description"><%= details ? details.description : '' %></textarea>
    </div>

    <div class="btn-container">
      <button type="submit" class="btn-submit"><%= details ? 'Save Changes' : 'Create Part' %></button>
      <a href="<%= details ? '/parts/' + details.id : '/' %>" class="btn-cancel">Cancel</a>
    </div>

  </form>

</body>
</html>